{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "aurobotix",
  "compatibility_date": "2026-05-01",
  "observability": {
    "enabled": true
  },
  "main": "./.output/server/index.mjs",
  "assets": {
    "binding": "ASSETS",
    "directory": "./.output/public/"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ]
}